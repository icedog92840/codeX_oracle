# codeX Oracle local provider keys
# Copy this file to `.env.local`, paste only the keys you want to use, then restart the dev server.

# Recommended first for fundamentals and Graham/Buffett score inputs.
# SEC asks automated tools to identify themselves with a contact-style User-Agent.
SEC_EDGAR_USER_AGENT=

# Recommended first for analyzer quote + historical OHLC candles.
TWELVE_DATA_API_KEY=

# Recommended first for ticker news; also used as quote fallback.
FMP_API_KEY=

# Optional fallback for historical OHLC candles. Uses the free TIME_SERIES_DAILY endpoint.
ALPHA_VANTAGE_API_KEY=

# Optional no-cost news fallback. Include `{ticker}` in the URL where the ticker should be inserted.
STOCK_NEWS_RSS_URL_TEMPLATE=

# Optional custom SQLite path. Leave blank to use `.data/codex-oracle.db`.
CODEX_ORACLE_DB_PATH=
